{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "dialog:allow-open",
    "dialog:allow-save",
    "process:default",
    "updater:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/pojianbing" }
      ]
    }
  ]
}
